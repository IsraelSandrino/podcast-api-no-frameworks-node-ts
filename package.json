{
  "name": "podcast-manager-api-nodejs-typescript",
  "version": "1.0.0",
  "description": "Um app ao estilo netflix, aonde possa centralizar diferentes episódios podcasts separados por categorias",
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "start:dev": "tsx --env-file=.env src/server.ts",
