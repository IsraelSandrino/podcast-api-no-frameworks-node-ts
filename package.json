    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/rss": "^0.0.32",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
